{
	"repoName": "pixelpulse",
	"name": "Pixel Pulse (live audio-reactive)",
	"author": "joeskolengaden",
	"description": "Live audio-reactive lighting: captures a USB audio input, analyzes it in real time (level / bands / beat), and modulates the channel data so the lights react to the room audio. Phase 1: level->brightness, beat->flash.",
	"homeURL": "https://github.com/joeskolengaden/pixelpulse",
	"srcURL": "https://github.com/joeskolengaden/pixelpulse.git",
	"bugURL": "https://github.com/joeskolengaden/pixelpulse/issues",
	"allowUpdates": 1,
	"hasSettingsPage": 1,
	"pluginType": "channelData",
	"pipelineStage": "modifyChannelData",
	"appSchemaVersion": 1,
	"settingsFile": "config/plugin.pixelpulse",
	"settingsSchema": [
		{ "key": "enabled", "label": "Plugin enabled", "type": "bool", "default": false, "group": "general", "appliesLive": true },
		{ "key": "onlyWhenPlaying", "label": "Only while a sequence is playing", "type": "bool", "default": true, "group": "general", "appliesLive": true },
		{ "key": "audioDevice", "label": "Audio input device", "type": "string", "default": "default", "group": "audio", "appliesLive": true, "help": "ALSA capture device for the USB input, e.g. hw:1,0" },
		{ "key": "sampleRate", "label": "Sample rate", "type": "enum", "default": "44100", "options": ["44100", "48000"], "group": "audio", "appliesLive": true },
		{ "key": "gain", "label": "Input gain", "type": "float", "default": 1.0, "min": 0.1, "max": 10, "step": 0.1, "group": "audio", "appliesLive": true, "widget": "slider" },
		{ "key": "gate", "label": "Noise gate", "type": "float", "default": 0.02, "min": 0, "max": 0.3, "step": 0.005, "group": "audio", "appliesLive": true, "widget": "slider", "help": "Below this level is treated as silence." },
		{ "key": "sensitivity", "label": "Beat sensitivity", "type": "float", "default": 1.5, "min": 1.05, "max": 3, "step": 0.05, "group": "audio", "appliesLive": true, "widget": "slider", "help": "Lower = more beats detected." },
		{ "key": "input_channel", "label": "Input channel", "type": "enum", "default": "mix", "options": ["mix", "left", "right"], "group": "tuning", "appliesLive": true, "help": "Stereo mix, or just the left/right channel of the input." },
		{ "key": "agc_enabled", "label": "Auto-gain (AGC)", "type": "bool", "default": true, "group": "tuning", "appliesLive": true, "help": "Normalize loudness to the room automatically. Off = absolute, set with Input gain." },
		{ "key": "agc_speed", "label": "AGC speed", "type": "float", "default": 0.5, "min": 0, "max": 1, "step": 0.05, "group": "tuning", "appliesLive": true, "widget": "slider", "help": "How fast auto-gain adapts. Higher = snappier, lower = steadier." },
		{ "key": "smoothing", "label": "Smoothing", "type": "float", "default": 0.0, "min": 0, "max": 0.95, "step": 0.05, "group": "tuning", "appliesLive": true, "widget": "slider", "help": "Eases the fall of reactions so they breathe instead of flicker (instant attack, slow release)." },
		{ "key": "bass_trim", "label": "Bass trim", "type": "float", "default": 1.0, "min": 0, "max": 2, "step": 0.05, "group": "tuning", "appliesLive": true, "widget": "slider" },
		{ "key": "mid_trim", "label": "Mid trim", "type": "float", "default": 1.0, "min": 0, "max": 2, "step": 0.05, "group": "tuning", "appliesLive": true, "widget": "slider" },
		{ "key": "treble_trim", "label": "Treble trim", "type": "float", "default": 1.0, "min": 0, "max": 2, "step": 0.05, "group": "tuning", "appliesLive": true, "widget": "slider" },

		{ "key": "channelsPerPixel", "label": "Channels per pixel", "type": "enum", "default": "3", "options": ["3", "4"], "group": "range", "appliesLive": true },
		{ "key": "startChannel", "label": "Start channel", "type": "int", "default": 1, "min": 1, "max": 1048576, "step": 1, "group": "range", "appliesLive": true },
		{ "key": "channelCount", "label": "Channel count", "type": "int", "default": 1500, "min": 0, "max": 1048576, "step": 3, "group": "range", "appliesLive": true },

		{ "key": "br_enabled", "label": "Level → brightness", "type": "bool", "default": true, "group": "reactions", "appliesLive": true, "help": "Design brightness follows loudness." },
		{ "key": "br_min", "label": "Min brightness", "type": "int", "default": 15, "min": 0, "max": 100, "step": 1, "unit": "%", "group": "reactions", "appliesLive": true, "widget": "slider" },
		{ "key": "fl_enabled", "label": "Beat → flash", "type": "bool", "default": true, "group": "reactions", "appliesLive": true, "help": "White flash on each beat." },
		{ "key": "fl_intensity", "label": "Flash intensity", "type": "int", "default": 80, "min": 0, "max": 100, "step": 1, "unit": "%", "group": "reactions", "appliesLive": true, "widget": "slider" },

		{ "key": "vis_mode", "label": "Visualizer", "type": "enum", "default": "off", "options": ["off", "vu", "spectrum"], "group": "visualizer", "appliesLive": true, "help": "Generate pixels directly from the audio (overrides the design over the range)." },
		{ "key": "hu_enabled", "label": "Spectral hue drive", "type": "bool", "default": false, "group": "visualizer", "appliesLive": true, "help": "Shift the design's hue with the bass/treble balance." },
		{ "key": "hu_amount", "label": "Hue amount", "type": "int", "default": 60, "min": 0, "max": 180, "step": 5, "unit": "deg", "group": "visualizer", "appliesLive": true, "widget": "slider" },

		{ "key": "speed_mode", "label": "Audio → speed", "type": "enum", "default": "off", "options": ["off", "level", "beat"], "group": "speed", "appliesLive": true, "help": "Modulate playback speed from the audio. Light-only sequences (audio-backed shows are slaved to their media clock)." },
		{ "key": "speed_amount", "label": "Speed amount", "type": "int", "default": 50, "min": 0, "max": 300, "step": 5, "unit": "%", "group": "speed", "appliesLive": true, "widget": "slider", "help": "Max speed-up at full level/beat." },

		{ "key": "spatial_enabled", "label": "Spatial (xLights layout)", "type": "bool", "default": false, "group": "spatial", "appliesLive": true, "help": "Render the whole display from the audio by each prop's real-world position. Requires an uploaded xlights_rgbeffects.xml; overrides the range pipeline." },
		{ "key": "spatial_mode", "label": "Spatial mode", "type": "enum", "default": "bloom", "options": ["bloom", "spectrum", "vu", "radial"], "group": "spatial", "appliesLive": true, "help": "bloom = beats radiate from centre; spectrum = frequency across X; vu = loudness by height; radial = frequency centre-out." },
		{ "key": "spatial_intensity", "label": "Spatial intensity", "type": "int", "default": 100, "min": 0, "max": 200, "step": 5, "unit": "%", "group": "spatial", "appliesLive": true, "widget": "slider" },
		{ "key": "spatial_layoutUpload", "label": "Layout file (xlights_rgbeffects.xml)", "type": "file", "accept": ".xml", "uploadUrl": "plugin.php?plugin=pixelpulse&page=uploadlayout.php&nopage=1", "field": "layout", "group": "spatial", "appliesLive": true, "help": "Upload xlights_rgbeffects.xml; parsed on-device into per-prop positions + channel ranges." }
	],
	"versions": [
		{ "minFPPVersion": "5.0", "maxFPPVersion": "0", "branch": "main", "sha": "" }
	]
}
